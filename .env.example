# ag_foundation environment configuration
# Copy this file to .env and fill in your values
# .env is gitignored and will not be committed

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider API Keys
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key (required for LLM mode)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Development Mode
# ─────────────────────────────────────────────────────────────────────────────

# Enable manual mode for development/testing (set to "1" to enable)
# AG_DEV=1

# ─────────────────────────────────────────────────────────────────────────────
# Optional Configuration Overrides
# ─────────────────────────────────────────────────────────────────────────────

# Override config file location (default: ~/.ag/config.yaml)
# AG_CONFIG_PATH=

# Default workspace path
# AG_WORKSPACE=

# Default LLM provider (openai, anthropic, local)
# AG_LLM_PROVIDER=openai

# Default model for OpenAI
# AG_LLM_MODEL=gpt-4o-mini
